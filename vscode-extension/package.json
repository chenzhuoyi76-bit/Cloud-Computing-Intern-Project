{
  "name": "cloud-cicd-assistant",
  "displayName": "Cloud CI/CD Assistant",
  "description": "A minimal VS Code extension for the AI CI/CD assistant.",
  "version": "0.0.1",
  "publisher": "local",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:cloudCicdAssistant.askIntent"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cloudCicdAssistant.askIntent",
        "title": "Cloud CI/CD: Ask Assistant"
      }
    ],
    "configuration": {
      "title": "Cloud CI/CD Assistant",
      "properties": {
        "cloudCicdAssistant.apiUrl": {
          "type": "string",
          "default": "http://127.0.0.1:5000/api/llm/intent",
          "description": "Backend API URL for intent recognition."
        }
      }
    }
  },
  "scripts": {
    "lint": "echo No lint configured"
  }
}
